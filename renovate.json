{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":dependencyDashboard"],
  "nix": {
    "enabled": true
  },
  "flux": {
    "enabled": true,
    "fileMatch": ["\\.yaml$"]
  },
  "kustomize": {
    "enabled": true,
    "fileMatch": ["kustomization\\.yaml$"]
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "matchDepTypes": ["flake"],
      "groupName": "Nix Flake inputs"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "groupName": "non-major updates"
    },
    {
      "matchManagers": ["flux"],
      "groupName": "flux dependencies",
      "addLabels": ["flux", "monitoring"]
    }
  ]
}
